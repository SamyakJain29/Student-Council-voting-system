<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<StackPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.voting.controller.LoginController" styleClass="root">
    <VBox alignment="CENTER" maxWidth="400" maxHeight="450" styleClass="card" spacing="20">
        <Label text="Sign In" styleClass="title-label"/>
        <Label text="Student Council Voting System" styleClass="subtitle-label"/>
        
        <VBox spacing="10" alignment="CENTER_LEFT">
            <Label text="Student ID" />
            <TextField fx:id="studentIdField" promptText="Enter your Student ID" styleClass="text-field" prefWidth="300" prefHeight="40"/>
        </VBox>
        
        <VBox spacing="10" alignment="CENTER_LEFT">
            <Label text="Password" />
            <PasswordField fx:id="passwordField" promptText="Enter your Password" styleClass="password-field" prefWidth="300" prefHeight="40"/>
        </VBox>
        
        <Button text="Login" onAction="#handleLogin" styleClass="btn-primary" prefWidth="300" prefHeight="40">
            <VBox.margin><Insets top="10"/></VBox.margin>
        </Button>
        
        <HBox alignment="CENTER" spacing="5">
            <Label text="Don't have an account?" />
            <Button text="Register Here" onAction="#goToRegister" styleClass="btn-secondary"/>
        </HBox>
    </VBox>
</StackPane>
